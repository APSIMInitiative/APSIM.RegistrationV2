
<div class="card card-layout text-center">
    <div class="card-body">
        <h5 class="card-title">@Title</h5>
        <p class="card-text">@Description</p>
    </div>
</div>

@code{
    [Parameter]
    public required string Title { get; set; }

    [Parameter]
    public required string Description { get; set; }
}